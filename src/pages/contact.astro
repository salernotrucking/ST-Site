---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact | Salerno Trucking" description="Contact Salerno Trucking for general questions, concrete delivery, fleet support, and partnership opportunities.">
<section class="contact-hero"><div class="container narrow centered reveal"><p class="eyebrow light">Contact Salerno Trucking</p><h1>Let's Start a Conversation.</h1><p class="lead">Whether you need fleet capacity, concrete delivery, or general information, our team is ready to help.</p></div></section>
<section class="section"><div class="container contact">
<div class="reveal contact-details"><p class="eyebrow">Get in Touch</p><h2>Clear Communication From the First Call.</h2><div class="contact-list"><a href="tel:+15625532989"><span>Phone</span><strong>(562) 553-2989</strong></a><a href="mailto:info@salernotrucking.com"><span>General Email</span><strong>info@salernotrucking.com</strong></a><a href="mailto:dispatch@salernotrucking.com"><span>Dispatch</span><strong>dispatch@salernotrucking.com</strong></a><div><span>Location</span><strong>Phoenix, Arizona</strong></div></div><div class="hours"><h3>Business Hours</h3><p>Monday–Friday: 7:00 AM–5:00 PM<br/>Saturday: 8:00 AM–12:00 PM<br/>Sunday: Closed</p></div></div>
<form class="form reveal" name="general-contact" method="POST" data-netlify="true" action="/thank-you"><input type="hidden" name="form-name" value="general-contact"/><div class="row"><label>Full Name<input required name="name" autocomplete="name"/></label><label>Company<input name="company" autocomplete="organization"/></label></div><div class="row"><label>Phone<input name="phone" type="tel" autocomplete="tel"/></label><label>Email<input required name="email" type="email" autocomplete="email"/></label></div><label>How Can We Help?<select required name="inquiry-type"><option value="">Select one</option><option>General Question</option><option>Ready-Mix Producer Fleet Support</option><option>Concrete Delivery</option><option>Employment</option><option>Other</option></select></label><label>Message<textarea required name="message" rows="7"></textarea></label><button class="btn" type="submit">Send Message</button></form>
</div></section></Layout>
