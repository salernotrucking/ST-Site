import Layout from '../layouts/Layout.astro';import PageHero from '../components/PageHero.astro';
---<Layout title="Partner With Us | Salerno Trucking" description="Contact Salerno Trucking about mixer truck fleet capacity or concrete delivery."><PageHero eyebrow="Start a Conversation" title="Let's Build Something Strong Together." text="Tell us what your operation or project needs. Our team will follow up to discuss capacity, scheduling, and the right service approach." image="/images/fleet/pump-project.webp"/><section class="section"><div class="container contact"><div class="reveal"><p class="eyebrow">Contact Salerno Trucking</p><h2>Professional Service Starts With Clear Communication.</h2><p class="lead">Discuss fleet support, concrete delivery, project requirements, or a long-term partnership.</p><a href="tel:+15625532989"><strong>Phone</strong><br/>(562) 553-2989</a><br/><br/><a href="mailto:dispatch@salernotrucking.com"><strong>Email</strong><br/>dispatch@salernotrucking.com</a></div><form class="form reveal" name="partner-inquiry" method="POST" data-netlify="true" action="/thank-you"><input type="hidden" name="form-name" value="partner-inquiry"/><div class="row"><label>Name<input required name="name"/></label><label>Company<input name="company"/></label></div><div class="row"><label>Phone<input required name="phone" type="tel"/></label><label>Email<input required name="email" type="email"/></label></div><label>Project Type<select required name="project-type"><option value="">Select one</option><option>Ready-Mix Producer Fleet Capacity</option><option>Long-Term Contract</option><option>Seasonal Support</option><option>Other</option></select></label><label>Message<textarea required name="message" rows="6"></textarea></label><button class="btn" type="submit">Submit Inquiry</button></form></div></section></Layout>