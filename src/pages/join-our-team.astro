---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Join Our Team | Salerno Trucking" description="Join the Salerno Trucking talent pool for Ready-Mix Driver and Fleet Maintenance opportunities."><section class="team-hero"><div class="container narrow centered reveal"><img src="/images/logo/iron-cross-white.png" alt="Salerno Trucking black and white iron cross logo"/><p class="eyebrow light">Join Our Team</p><h1>Join Our Talent Pool</h1><p class="lead">We're always interested in connecting with dependable professionals who take pride in safety, reliability, and customer service.</p></div></section><section class="section"><div class="container contact"><div class="reveal"><p class="eyebrow">Future Opportunities</p><h2>Build Your Career With Salerno Trucking.</h2><p class="lead">Submit your information and we'll reach out when an opportunity aligns with your experience.</p><h3>Positions</h3><p>Ready-Mix Driver<br/>Fleet Maintenance</p></div><form class="form reveal" name="talent-pool" method="POST" data-netlify="true" enctype="multipart/form-data" action="/thank-you"><input type="hidden" name="form-name" value="talent-pool"/><div class="row"><label>Full Name<input required name="name"/></label><label>Phone<input required name="phone" type="tel"/></label></div><div class="row"><label>Email<input required name="email" type="email"/></label><label>Current City & State<input required name="location"/></label></div><label>Position of Interest<select required name="position"><option value="">Select one</option><option>Ready-Mix Driver</option><option>Fleet Maintenance</option></select></label><div class="row"><label>Years of Experience<input name="experience" type="number" min="0"/></label><label>Earliest Available Start Date<input name="start-date" type="date"/></label></div><div class="row"><label>CDL Class (if applicable)<input name="cdl-class"/></label><label>Endorsements<input name="endorsements"/></label></div><label>Current Employer (Optional)<input name="current-employer"/></label><label>Willing to Travel?<select name="travel"><option>Yes</option><option>No</option></select></label><label>Resume Upload<input required name="resume" type="file" accept=".pdf,.doc,.docx"/></label><label>Certifications Upload (Optional)<input name="certifications" type="file" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx"/></label><label>Tell Us About Yourself<textarea name="about" rows="6"></textarea></label><button class="btn" type="submit">Join Our Talent Pool</button></form></div></section></Layout>
