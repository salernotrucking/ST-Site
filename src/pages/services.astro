---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout
  title="Services | Salerno Trucking"
  description="Fleet capacity for ready-mix producers and dependable concrete delivery for placement contractors."
>
  <PageHero
    eyebrow="Our Services"
    title="Flexible Capacity. Dependable Delivery."
    text="Solutions designed around the real operating needs of ready-mix producers and concrete placement contractors."
    image="/images/fleet/batch-plant.webp"
  />

  <section class="section">
    <div class="container service-grid">
      <article class="service-panel reveal">
        <p class="eyebrow">For Ready-Mix Producers</p>
        <h2>Fleet Capacity</h2>
        <p class="lead">Increase production without compromising service quality.</p>
        <ul>
          <li>Long-term and seasonal capacity</li>
          <li>Peak-demand support</li>
          <li>Experienced mixer operators</li>
          <li>Professional representation</li>
          <li>Reliable equipment</li>
          <li>Nationwide mobilization</li>
        </ul>
        <a class="btn" href="/partner-with-us/">Discuss Capacity</a>
      </article>

      <article class="service-panel black reveal">
        <p class="eyebrow">For Placement Contractors</p>
        <h2>Concrete Delivery</h2>
        <p class="lead">Straightforward support from material sourcing through placement.</p>
        <ul>
          <li>Single-load concrete delivery</li>
          <li>Material sourcing coordination</li>
          <li>Transparent pricing</li>
          <li>No standing time charges</li>
          <li>Reliable scheduling</li>
          <li>Professional communication</li>
        </ul>
        <a class="btn light-btn" href="/request-concrete/">Request Delivery</a>
      </article>
    </div>
  </section>

  <section class="section muted">
    <div class="container narrow centered reveal">
      <p class="eyebrow">Our Standard</p>
      <h2>We Treat Every Delivery Like Our Reputation Is Riding on It.</h2>
      <p class="lead">Because it is—and so is yours.</p>
    </div>
  </section>

  <section class="cta">
    <div class="container centered">
      <h2>Tell Us What Your Project Needs.</h2>
      <div class="actions" style="justify-content:center">
        <a class="btn light-btn" href="/request-concrete/">Request Concrete</a>
        <a class="btn ghost" href="/partner-with-us/">Partner With Us</a>
      </div>
    </div>
  </section>
</Layout>
