---
import Layout from '../layouts/Layout.astro';import PageHero from '../components/PageHero.astro';
---
<Layout title="Request Concrete | Salerno Trucking" description="Request dependable concrete delivery in the Greater Phoenix Area with no standing time charges."><PageHero eyebrow="Greater Phoenix Area" title="Request Concrete" text="Dependable delivery, clear communication, and straightforward service for concrete placement contractors." image="/images/fleet/pump-project.webp"/><section class="section"><div class="container contact"><div class="reveal"><p class="eyebrow">No Standing Time Charges</p><h2>Keep Your Project Moving Without Unexpected Costs.</h2><p class="lead">We understand that the construction industry is unpredictable, with varying site conditions. We respect the work you do, and our goal is to keep your project moving forward—not add unexpected costs.</p><p><strong>Dispatch:</strong><br/><a href="mailto:dispatch@salernotrucking.com">dispatch@salernotrucking.com</a><br/><a href="tel:+15625532989">(562) 553-2989</a></p></div><form class="form reveal" name="request-concrete" method="POST" data-netlify="true" action="/thank-you"><input type="hidden" name="form-name" value="request-concrete"/><div class="row"><label>Name<input required name="name"/></label><label>Company<input name="company"/></label></div><div class="row"><label>Phone<input required name="phone" type="tel"/></label><label>Email<input required name="email" type="email"/></label></div><div class="row"><label>Project Address<input required name="project-address"/></label><label>Requested Date<input required name="requested-date" type="date"/></label></div><div class="row"><label>Concrete Quantity<input name="quantity" placeholder="Yards or estimated amount"/></label><label>Placement Type<select name="placement-type"><option value="">Select one</option><option>Residential</option><option>Commercial</option><option>Industrial</option><option>Other</option></select></label></div><label>Project Details<textarea required name="message" rows="6" placeholder="Mix requirements, access conditions, timing, and other details"></textarea></label><button class="btn" type="submit">Submit Request</button></form></div></section></Layout>
